# 기본: 텍스트 자동 정규화(저장소 LF)
* text=auto

# 셸 스크립트는 항상 LF (gradlew가 CRLF면 실행 깨짐)
*.sh    text eol=lf
gradlew text eol=lf

# Windows 배치는 CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# 바이너리 — diff/정규화 금지
*.jar   binary
*.war   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.pdf   binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary

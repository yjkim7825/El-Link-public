# EcoLink 백엔드 환경변수 예시. 복사해서 .env 로 만들고 값을 채우세요.
#   cp backend/.env.example backend/.env
# (application.yml 이 ${ENV:기본값} 형태로 읽습니다. dev 프로필은 대부분 기본값으로 동작)
# ⚠ 실제 .env 는 절대 커밋하지 마세요(.gitignore 로 제외됨). 운영 값은 호스팅 대시보드에 등록.

# ===== AI (Gemini) =====
# 없어도 자료 저장·견적·서류 등 다른 기능은 정상 동작합니다.
# AI 분석/협업 아이디어 추천 기능만 비활성화됩니다. 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===== 인증 (JWT) =====
# 운영에서는 반드시 32바이트 이상 무작위 시크릿으로 설정하세요. dev는 미설정 시 기본값 사용.
ELLINK_JWT_SECRET=
# 로컬(http)에서는 false, 운영(https)에서는 true (refresh 쿠키 Secure 속성)
ELLINK_JWT_REFRESH_COOKIE_SECURE=false
# 프론트/백 분리 도메인(Vercel↔Railway) 배포 시 None(반드시 Secure=true 동반). 같은 도메인이면 Strict.
REFRESH_COOKIE_SAME_SITE=Strict

# ===== CORS =====
# 콤마로 여러 개 가능. 운영 예: https://el-link-public.vercel.app
ELLINK_CORS_ORIGINS=http://localhost:5173

# ===== DB (prod 프로필) =====
# dev 는 H2 인메모리라 불필요. 운영은 Supabase Postgres.
# 예: jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/ellink
DB_USERNAME=postgres
DB_PASSWORD=
# 첫 배포만 update(스키마 자동 생성), 안정화되면 제거(기본 validate).
JPA_DDL_AUTO=validate

# ===== 스토리지 (prod 프로필 = Supabase Storage) =====
# dev 는 로컬 디스크(./storage) 사용. 운영은 Supabase Storage (private 버킷 + service_role 키).
# ⚠ service_role 키는 백엔드 전용 비밀입니다. 절대 프론트/클라이언트에 노출 금지.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=ellink-files

# ===== 서버 포트 =====
# Railway 등은 PORT 를 자동 주입합니다. 직접 설정 불필요(미설정 시 8080).
# PORT=8080

# EcoLink 백엔드 환경변수 예시. 복사해서 .env 로 만들고 값을 채우세요.
#   cp backend/.env.example backend/.env
# (application.yml 이 ${ENV:기본값} 형태로 읽습니다. dev 프로필은 대부분 기본값으로 동작)

# ===== AI (Gemini) =====
# 없어도 자료 저장·견적·서류 등 다른 기능은 정상 동작합니다.
# AI 분석/협업 제안 기능만 비활성화됩니다. 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===== 인증 (JWT) =====
# 운영에서는 반드시 32바이트 이상 무작위 시크릿으로 설정하세요. dev는 미설정 시 기본값 사용.
ELLINK_JWT_SECRET=
# 로컬(http)에서는 false, 운영(https)에서는 true (refresh 쿠키 Secure 속성)
ELLINK_JWT_REFRESH_COOKIE_SECURE=false

# ===== CORS =====
ELLINK_CORS_ORIGINS=http://localhost:5173

# ===== DB (prod 프로필) =====
# dev 는 H2 인메모리라 불필요. 운영 PostgreSQL 사용 시 설정.
DB_URL=jdbc:postgresql://localhost:5432/ellink
DB_USERNAME=
DB_PASSWORD=

# ===== 스토리지 (prod, S3 호환 — Cloudflare R2 / Supabase) =====
# dev 는 로컬 디스크(./storage) 사용. 운영 호스팅 시 설정.
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

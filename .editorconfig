# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Java / Gradle (Kotlin DSL) — 4-space convention
[*.{java,kt,kts,gradle}]
indent_size = 4

# Web / config — 2-space
[*.{ts,tsx,js,jsx,json,css,scss,html,yml,yaml}]
indent_size = 2

# Markdown — keep trailing spaces (hard line breaks)
[*.md]
trim_trailing_whitespace = false

# Windows batch / wrapper scripts use CRLF
[*.{bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab
